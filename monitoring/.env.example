***REMOVED*** Monitoring Stack Environment Variables
***REMOVED*** Copy this file to .env and configure as needed

***REMOVED*** Environment identifier
ENVIRONMENT=production

***REMOVED*** Database connection for PostgreSQL exporter
DB_USER=scheduler
DB_PASSWORD=your_db_password_here
DB_NAME=residency_scheduler

***REMOVED*** Grafana settings
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password
GRAFANA_ROOT_URL=http://localhost:3001

***REMOVED*** SMTP settings for email alerts
SMTP_HOST=smtp.example.com:587
SMTP_FROM=alerts@residency-scheduler.local
SMTP_USERNAME=
SMTP_PASSWORD=

***REMOVED*** Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

***REMOVED*** PagerDuty integration
PAGERDUTY_SERVICE_KEY=your_pagerduty_key_here

***REMOVED*** Alert email recipients
ALERT_EMAIL=ops@residency-scheduler.local
CRITICAL_ALERT_EMAIL=oncall@residency-scheduler.local
DBA_EMAIL=dba@residency-scheduler.local
INFRA_EMAIL=infra@residency-scheduler.local
SCHEDULING_ALERT_EMAIL=scheduling@residency-scheduler.local
COMPLIANCE_EMAIL=compliance@residency-scheduler.local
