***REMOVED*** Application
APP_NAME=Residency Scheduler
APP_VERSION=1.0.0
DEBUG=false

***REMOVED*** Database
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/residency_scheduler

***REMOVED*** Database Connection Pool (see docs/ARCHITECTURE.md for sizing guidelines)
***REMOVED*** DB_POOL_SIZE=10          ***REMOVED*** Base pool size (default: 10)
***REMOVED*** DB_POOL_MAX_OVERFLOW=20  ***REMOVED*** Additional connections allowed (default: 20)
***REMOVED*** DB_POOL_TIMEOUT=30       ***REMOVED*** Seconds to wait for connection (default: 30)
***REMOVED*** DB_POOL_RECYCLE=1800     ***REMOVED*** Recycle connections after N seconds (default: 1800)
***REMOVED*** DB_POOL_PRE_PING=true    ***REMOVED*** Verify connections before use (default: true)

***REMOVED*** Redis / Celery (required for resilience framework background tasks)
***REMOVED*** REDIS_PASSWORD is required for authentication (use strong random value in production)
***REMOVED*** Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
***REMOVED*** Note: If REDIS_PASSWORD is set, it will be automatically added to URLs by the application

***REMOVED*** Security
SECRET_KEY=your-secret-key-change-in-production
WEBHOOK_SECRET=your-webhook-secret-change-in-production

***REMOVED*** Token Configuration
***REMOVED*** ACCESS_TOKEN_EXPIRE_MINUTES=15  ***REMOVED*** 15 minutes (default)
***REMOVED*** REFRESH_TOKEN_EXPIRE_DAYS=7     ***REMOVED*** 7 days (default)
***REMOVED*** REFRESH_TOKEN_ROTATE=true         ***REMOVED*** Issue new refresh token on each use (default: true)
***REMOVED***                                   ***REMOVED*** When enabled, old refresh tokens are blacklisted
***REMOVED***                                   ***REMOVED*** to prevent reuse after rotation (security best practice)

***REMOVED*** CORS (Cross-Origin Resource Sharing)
***REMOVED*** Restrict to explicit origins in production - NEVER use "*" wildcard
***REMOVED*** For development: CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
***REMOVED*** For production: CORS_ORIGINS=["https://scheduler.hospital.org","https://scheduler-staging.hospital.org"]
CORS_ORIGINS=["http://localhost:3000"]

***REMOVED*** Optional: Use regex pattern for flexible domain matching
***REMOVED*** Example: Allow all subdomains of hospital.org in production
***REMOVED*** CORS_ORIGINS_REGEX=^https://.*\.hospital\.org$
***REMOVED*** Security: Regex patterns should be as specific as possible
***REMOVED*** CORS_ORIGINS_REGEX=

***REMOVED*** Trusted Proxies (for X-Forwarded-For header validation)
***REMOVED*** Only trust X-Forwarded-For from these IPs to prevent rate limit bypass
***REMOVED*** Empty list uses direct client IP (safest default for non-proxied setups)
***REMOVED*** TRUSTED_PROXIES=["10.0.0.1", "172.16.0.0/12"]  ***REMOVED*** Example: internal load balancer IPs

***REMOVED*** Resilience Framework Configuration
***REMOVED*** Utilization thresholds based on queuing theory - adjust for your program's needs
***REMOVED*** See docs/RESILIENCE_FRAMEWORK.md and docs/runbooks/resilience-alerts.md
***REMOVED*** RESILIENCE_WARNING_THRESHOLD=0.70     ***REMOVED*** Yellow level (default: 70%)
***REMOVED*** RESILIENCE_MAX_UTILIZATION=0.80       ***REMOVED*** Orange level (default: 80%)
***REMOVED*** RESILIENCE_CRITICAL_THRESHOLD=0.90    ***REMOVED*** Red level (default: 90%)
***REMOVED*** RESILIENCE_EMERGENCY_THRESHOLD=0.95   ***REMOVED*** Black level (default: 95%)

***REMOVED*** Auto-activation settings
***REMOVED*** RESILIENCE_AUTO_ACTIVATE_DEFENSE=true  ***REMOVED*** Auto defense level transitions
***REMOVED*** RESILIENCE_AUTO_ACTIVATE_FALLBACK=false ***REMOVED*** Require manual fallback activation
***REMOVED*** RESILIENCE_AUTO_SHED_LOAD=true          ***REMOVED*** Auto load shedding

***REMOVED*** Monitoring intervals
***REMOVED*** RESILIENCE_HEALTH_CHECK_INTERVAL_MINUTES=15    ***REMOVED*** Health check frequency
***REMOVED*** RESILIENCE_CONTINGENCY_ANALYSIS_INTERVAL_HOURS=24  ***REMOVED*** N-1/N-2 analysis frequency

***REMOVED*** Alert settings (configure for production)
***REMOVED*** RESILIENCE_ALERT_RECIPIENTS=["admin@hospital.org"]  ***REMOVED*** Email recipients
***REMOVED*** RESILIENCE_SLACK_CHANNEL=***REMOVED***resilience-alerts         ***REMOVED*** Slack channel
