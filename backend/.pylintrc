[MAIN]
***REMOVED*** Files or directories to be skipped
ignore=alembic,tests,venv,.venv,__pycache__

***REMOVED*** Use multiple processes for faster linting
jobs=0

***REMOVED*** Python version for type inference
py-version=3.11

***REMOVED*** Minimum line similarity for code duplication detection
min-similarity-lines=10

[MESSAGES CONTROL]
***REMOVED*** Disable messages that are not relevant for this project
disable=
    ***REMOVED*** Import errors - dependencies may not be installed in lint environment
    import-error,
    ***REMOVED*** Too strict for complex business logic services
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-many-instance-attributes,
    too-many-branches,
    too-many-return-statements,
    too-many-lines,
    too-many-nested-blocks,
    too-few-public-methods,
    ***REMOVED*** Code duplication - handled at code review level
    duplicate-code,
    ***REMOVED*** Import organization - handled by ruff/isort
    wrong-import-order,
    wrong-import-position,
    ***REMOVED*** These are design decisions
    too-many-statements,
    too-many-public-methods,
    ***REMOVED*** Lazy/conditional imports are intentional
    import-outside-toplevel,
    ***REMOVED*** f-strings in logging is modern Python style
    logging-fstring-interpolation,
    ***REMOVED*** Sometimes else after return is more readable
    no-else-return,
    ***REMOVED*** Intentional for module-level singletons
    global-statement,
    ***REMOVED*** Often intentional for API consistency/interface compliance
    unused-argument,
    ***REMOVED*** Allow catching broad exceptions for error handling
    broad-exception-caught,
    ***REMOVED*** Line length handled by black/ruff
    line-too-long,

[FORMAT]
***REMOVED*** Maximum number of characters on a single line
max-line-length=120

***REMOVED*** Expected format of line ending
expected-line-ending-format=LF

[DESIGN]
***REMOVED*** Maximum number of arguments for function / method
max-args=12

***REMOVED*** Maximum number of locals for function / method
max-locals=25

***REMOVED*** Maximum number of return / yield for function / method
max-returns=10

***REMOVED*** Maximum number of branch for function / method
max-branches=20

***REMOVED*** Maximum number of attributes for a class
max-attributes=20

[BASIC]
***REMOVED*** Good variable names which should always be accepted
good-names=i,j,k,ex,_,db,id,pk,dt,df,n,x,y,ax,f,e,ws,X,F

***REMOVED*** Regular expression matching correct variable names
variable-rgx=[a-z_][a-z0-9_]{0,30}$

***REMOVED*** Regular expression matching correct constant names
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__))$

***REMOVED*** Regular expression matching correct function names
function-rgx=[a-z_][a-z0-9_]{2,50}$

***REMOVED*** Regular expression matching correct method names
method-rgx=[a-z_][a-z0-9_]{2,50}$

***REMOVED*** Regular expression matching correct class names
class-rgx=[A-Z_][a-zA-Z0-9]+$

[LOGGING]
***REMOVED*** Allow f-strings in logging (modern Python style)
logging-format-style=new

[SIMILARITIES]
***REMOVED*** Minimum lines number of a similarity
min-similarity-lines=10

***REMOVED*** Ignore comments when computing similarities
ignore-comments=yes

***REMOVED*** Ignore docstrings when computing similarities
ignore-docstrings=yes

***REMOVED*** Ignore imports when computing similarities
ignore-imports=yes

[TYPECHECK]
***REMOVED*** List of decorators that produce context managers
contextmanager-decorators=contextlib.contextmanager

***REMOVED*** List of members which are set dynamically
generated-members=

[VARIABLES]
***REMOVED*** List of additional names supposed to be defined in builtins
additional-builtins=

***REMOVED*** A regular expression matching the name of dummy variables
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+?$)|dummy|^ignored_|^unused_

[EXCEPTIONS]
***REMOVED*** Exceptions that will emit a warning when caught
overgeneral-exceptions=builtins.BaseException
