{
  "$schema": "https://antigravityai.org/schemas/settings.json",
  "version": "1.0.0",
  "lastUpdated": "2026-02-14",

  "autopilot": {
    "enabled": true,
    "mode": "A",
    "description": "Single agent, autonomous with guardrails",

    "guardrails": {
      "level": "strict",
      "customRulesFile": "./guardrails.md"
    },

    "timeouts": {
      "singleTaskMaxMinutes": 15,
      "sessionMaxMinutes": 120,
      "idleBeforePauseMinutes": 5
    },

    "retries": {
      "maxRetries": 2,
      "backoffMultiplier": 2
    },

    "logging": {
      "enabled": true,
      "level": "info",
      "directory": "./logs"
    }
  },

  "managerView": {
    "enabled": true,
    "status": "ACTIVE",
    "configFile": "./FUTURE_B_MANAGER_VIEW.md",
    "note": "Parallel subagent orchestration - activated 2026-02-14"
  },

  "autoTriggers": {
    "enabled": false,
    "status": "FUTURE_C",
    "configFile": "./FUTURE_C_AUTO_TRIGGERS.md",
    "note": "Webhook and scheduled triggers - not yet activated"
  },

  "hybridOrchestration": {
    "enabled": false,
    "status": "FUTURE_D",
    "configFile": "./FUTURE_D_HYBRID_MODEL_ORCHESTRATION.md",
    "note": "Opus tactician + Qwen squad - concept for evaluation"
  },

  "models": {
    "default": "claude-sonnet-4-5-20250929",
    "thinking": "claude-sonnet-4-5-20250929",
    "complex": "claude-opus-4-6",
    "quick": "gemini-3-flash"
  },

  "skills": {
    "autoLoad": true,
    "directory": "../.claude/skills"
  },

  "commands": {
    "autoLoad": true,
    "directory": "../.claude/commands"
  },

  "mcp": {
    "autoConnect": true,
    "serverPath": "../mcp-server",
    "healthCheckInterval": 60,
    "configMethod": "gemini-settings-json",
    "note": "Configured in ~/.gemini/settings.json mcpServers (httpUrl), not .mcp.json"
  },

  "projectContext": {
    "instructionsFile": "../GEMINI.md",
    "fallbackFile": "../CLAUDE.md",
    "architectureFile": "../ARCHITECTURE.md",
    "taskList": "../TODO.md",
    "humanTaskList": "../HUMAN_TODO.md"
  },

  "agentIdentity": {
    "claudeModels": {
      "identity": "ASTRONAUT",
      "model": "claude-opus-4-6",
      "note": "When Claude model selected, follow CLAUDE.md guardrails"
    },
    "geminiModels": {
      "identity": "AUTOPILOT",
      "model": "gemini-3-flash",
      "instructionsFile": "../GEMINI.md",
      "note": "Native Antigravity autopilot — follows GEMINI.md guardrails"
    }
  },

  "recovery": {
    "autoRecovery": true,
    "proceduresFile": "./recovery.md",
    "checkpointBeforeMajorChanges": true
  },

  "notifications": {
    "onEscalation": true,
    "onRecovery": true,
    "onSessionComplete": true
  }
}
