# MCP server local-native configuration
# Copy to mcp-server/.env for local development.

# Backend API connection
API_BASE_URL=http://localhost:8000
API_USERNAME=admin
API_PASSWORD=admin123

# MCP server runtime
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8080
MCP_LOG_LEVEL=INFO

# Optional hardening for remote access (leave unset for local-only use)
# MCP_API_KEY=
# MCP_ALLOW_LOCAL_DEV=true
