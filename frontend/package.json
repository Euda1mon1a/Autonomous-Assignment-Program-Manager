{
  "name": "residency-scheduler-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit",
    "type-check:all": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "npx playwright test --config=playwright.config.ci.ts",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "validate": "npm run type-check && npm run lint && npm run test",
    "generate:types": "./scripts/generate-api-types.sh",
    "generate:types:check": "./scripts/generate-api-types.sh --check",
    "generate:types:file": "openapi-typescript ./openapi.json -o src/types/api-generated.ts",
    "generate:test-fixtures": "npx tsx e2e/fixtures/generate-test-xlsx.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-spring/three": "9.7.3",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.16.7",
    "@tanstack/react-query": "^5.90.14",
    "axios": "^1.13.5",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.561.0",
    "next": "^15.5.12",
    "plotly.js": "^3.3.1",
    "plotly.js-dist-min": "^3.3.1",
    "postprocessing": "^6.38.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-plotly.js": "^2.6.0",
    "recharts": "^3.6.0",
    "three": "^0.164.1",
    "uuid": "^13.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
    "zod": "^4.3.2"
  },
  "overrides": {
    "glob": "^10.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@mswjs/interceptors": "^0.40.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-plotly.js": "^2.6.4",
    "@types/three": "0.164.0",
    "autoprefixer": "10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.12",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5",
    "undici": "^7.16.0",
    "xlsx-populate": "^1.21.0"
  },
  "volta": {
    "node": "22.22.0",
    "npm": "10.9.4"
  }
}
